# Copier en .env et remplir. .env est gitignored, .env.example ne l'est pas.

# Mistral (La Plateforme, free tier)
MISTRAL_API_KEY=

# Groq (fallback, free tier)
GROQ_API_KEY=

# Config runtime
GHOST_POKER_CONTROL_MODE=assist
GHOST_POKER_EXECUTION_SAFETY=dry_run
GHOST_POKER_CONTROL_GATE_MODE=disabled
GHOST_POKER_CONTROL_STATE_PATH=data/runtime/control_panel_state.json
GHOST_POKER_META_BACKEND=disabled
GHOST_POKER_META_MODEL=
GHOST_POKER_META_BASE_URL=
GHOST_POKER_META_API_KEY=
GHOST_POKER_LOG_LEVEL=INFO
GHOST_POKER_KILL_SWITCH_KEY=f12
